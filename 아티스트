<script>
// Staff lines
(function(){
  const s=document.getElementById('staff'),c=50,g=4;
  for(let i=-2;i<=2;i++){const l=document.createElement('div');l.className='line';l.style.top=(c+i*g)+'%';s.appendChild(l)}
})();

// Floating notes
(function(){
  const c=document.getElementById('notes'),sym=['♩','♪','♫','♬','𝄞','𝄢'];
  for(let i=0;i<20;i++){const n=document.createElement('span');n.className='note';n.textContent=sym[Math.floor(Math.random()*sym.length)];n.style.left=Math.random()*100+'%';n.style.fontSize=(1+Math.random()*2)+'rem';n.style.animationDuration=(12+Math.random()*18)+'s';n.style.animationDelay=Math.random()*15+'s';c.appendChild(n)}
})();

// Scroll reveal
const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis')})},{threshold:.12,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// Tabs
document.querySelectorAll('.svc-tab').forEach(t=>{t.addEventListener('click',()=>{document.querySelectorAll('.svc-tab').forEach(x=>x.classList.remove('active'));document.querySelectorAll('.svc-panel').forEach(x=>x.classList.remove('active'));t.classList.add('active');document.querySelector('[data-panel="'+t.dataset.tab+'"]').classList.add('active')})});

// Nav scroll effect
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>{nav.classList.toggle('scrolled',window.scrollY>80)},{passive:true});

// Mobile nav toggle
const toggle=document.getElementById('navToggle'),links=document.getElementById('navLinks');
toggle.addEventListener('click',()=>{links.classList.toggle('open')});
links.querySelectorAll('a').forEach(a=>{a.addEventListener('click',()=>{links.classList.remove('open')})});
</script>
