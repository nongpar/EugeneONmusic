<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EON Artist Management</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Noto+Serif+KR:wght@300;400;500;600;700&family=Noto+Sans+KR:wght@300;400;500;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&display=swap" rel="stylesheet">
<style>
:root {
  --midnight: #0c0f14;
  --deep: #13161e;
  --charcoal: #1c1f2a;
  --gold: #c8a45c;
  --gold-pale: #dcc07e;
  --gold-glow: rgba(200,164,92,0.15);
  --ivory: #f5f1ea;
  --cream: #ede8df;
  --warm: #d9d2c5;
  --text-dark: #1a1a1a;
  --text-body: #4a4640;
  --text-muted: #8a857d;
  --serif-display: 'Playfair Display', 'Noto Serif KR', serif;
  --serif-body: 'Cormorant Garamond', 'Noto Serif KR', serif;
  --sans: 'Noto Sans KR', sans-serif;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--sans);color:var(--text-dark);background:var(--ivory);overflow-x:hidden;-webkit-font-smoothing:antialiased}

.reveal{opacity:0;transform:translateY(40px);transition:opacity 1s var(--ease),transform 1s var(--ease)}
.reveal.vis{opacity:1;transform:translateY(0)}
.rd1{transition-delay:.1s}.rd2{transition-delay:.2s}.rd3{transition-delay:.3s}
.rd4{transition-delay:.4s}.rd5{transition-delay:.5s}.rd6{transition-delay:.6s}

/* ═══ NAV ═══ */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:20px 32px;display:flex;align-items:center;justify-content:space-between;transition:all .5s}
.nav.scrolled{background:rgba(12,15,20,0.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);padding:14px 32px;box-shadow:0 2px 24px rgba(0,0,0,0.3);border-radius:0 0 12px 12px}
.nav-brand{font-family:var(--serif-display);font-size:0.9rem;color:var(--gold);letter-spacing:3px;text-decoration:none;text-transform:uppercase;font-weight:500}
.nav-links{display:flex;gap:32px;align-items:center}
.nav-links a{font-family:var(--sans);font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.5);text-decoration:none;transition:color .3s;font-weight:400;position:relative}
.nav-links a:hover{color:var(--gold)}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--gold);transition:width .3s}
.nav-links a:hover::after{width:100%}

/* Mobile nav toggle */
.nav-toggle{display:none;background:none;border:none;cursor:pointer;padding:4px}
.nav-toggle span{display:block;width:20px;height:1.5px;background:var(--gold);margin:4px 0;transition:all .3s}

@media(max-width:768px){
  .nav-links{position:fixed;top:0;right:-100%;width:260px;height:100vh;background:var(--midnight);flex-direction:column;justify-content:center;gap:28px;transition:right .4s var(--ease);padding:24px}
  .nav-links.open{right:0}
  .nav-links a{font-size:0.85rem;letter-spacing:3px}
  .nav-toggle{display:block;z-index:101}
}

/* ═══ HERO ═══ */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--midnight);overflow:hidden}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 120% 80% at 30% 20%,rgba(107,58,74,0.25) 0%,transparent 60%),radial-gradient(ellipse 80% 120% at 75% 80%,rgba(58,90,94,0.2) 0%,transparent 55%),radial-gradient(circle at 50% 50%,rgba(200,164,92,0.06) 0%,transparent 50%)}
.hero-staff{position:absolute;inset:0;opacity:0.04}
.hero-staff .line{position:absolute;left:0;right:0;height:1px;background:var(--gold)}
.hero-notes{position:absolute;inset:0;pointer-events:none}
.hero-notes .note{position:absolute;color:rgba(200,164,92,0.12);animation:floatNote linear infinite}
@keyframes floatNote{0%{transform:translateY(110vh) rotate(0deg);opacity:0}5%{opacity:1}95%{opacity:1}100%{transform:translateY(-10vh) rotate(20deg);opacity:0}}

.hero-content{position:relative;z-index:3;text-align:center;padding:0 24px;max-width:800px}
.hero-content>*{opacity:0;transform:translateY(30px);animation:heroIn 1.2s var(--ease) forwards}
.hero-content>*:nth-child(1){animation-delay:.3s}
.hero-content>*:nth-child(2){animation-delay:.6s}
.hero-content>*:nth-child(3){animation-delay:.9s}
.hero-content>*:nth-child(4){animation-delay:1.2s}
.hero-content>*:nth-child(5){animation-delay:1.5s}
@keyframes heroIn{to{opacity:1;transform:translateY(0)}}

.hero-label{display:inline-block;font-family:var(--sans);font-size:0.7rem;letter-spacing:8px;text-transform:uppercase;color:var(--gold);border:1px solid rgba(200,164,92,0.3);padding:10px 28px;margin-bottom:40px;border-radius:28px}
.hero-title{font-family:var(--serif-display);font-size:clamp(3rem,8vw,6rem);font-weight:400;color:#fff;line-height:1.1;margin-bottom:12px;letter-spacing:-2px}
.hero-title .italic{font-style:italic;background:linear-gradient(135deg,var(--gold-pale),var(--gold),#a8884a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-family:var(--serif-body);font-size:clamp(1.1rem,2.5vw,1.5rem);color:rgba(255,255,255,0.4);font-weight:300;font-style:italic;letter-spacing:1px;margin-bottom:50px}
.hero-tagline{font-family:var(--serif-body);font-size:1.15rem;color:rgba(255,255,255,0.55);font-weight:400;line-height:1.8}
.hero-discover{display:inline-block;margin-top:60px;font-size:0.7rem;letter-spacing:4px;color:rgba(200,164,92,0.5);text-decoration:none;text-transform:uppercase;transition:color .3s}
.hero-discover:hover{color:var(--gold)}

.hero-scroll{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);width:24px;height:40px;border:1.5px solid rgba(200,164,92,0.35);border-radius:12px;display:flex;justify-content:center;padding-top:8px}
.hero-scroll::before{content:'';width:3px;height:8px;background:var(--gold);border-radius:2px;animation:scrollDot 2s ease-in-out infinite}
@keyframes scrollDot{0%,100%{transform:translateY(0);opacity:1}50%{transform:translateY(12px);opacity:.3}}

/* ═══ HERO → LIGHT TRANSITION ═══ */
.hero-fade{height:160px;background:linear-gradient(to bottom,var(--midnight),var(--ivory));position:relative}
.hero-fade::after{content:'♪';position:absolute;bottom:40px;left:50%;transform:translateX(-50%);font-family:var(--serif-body);font-size:1.2rem;color:var(--warm);opacity:0.6}

/* ═══ SECTIONS ═══ */
section{padding:120px 24px}
.container{max-width:1100px;margin:0 auto}
.sec-label{font-family:var(--sans);font-size:0.68rem;letter-spacing:6px;text-transform:uppercase;color:var(--gold);margin-bottom:20px;font-weight:500}
.sec-title{font-family:var(--serif-display);font-size:clamp(2rem,4.5vw,3rem);font-weight:400;line-height:1.25;margin-bottom:20px;letter-spacing:-0.5px}
.sec-desc{font-family:var(--serif-body);font-size:1.15rem;line-height:1.9;color:var(--text-body);max-width:640px;font-weight:400}
.music-divider{display:flex;align-items:center;justify-content:center;gap:16px;padding:20px 0;max-width:200px;margin:0 auto;color:var(--warm);font-size:0.85rem;font-family:var(--serif-body);background:transparent}
.music-divider::before,.music-divider::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(200,164,92,0.25),transparent)}

/* ═══ VISION ═══ */
.vision{background:var(--ivory);position:relative;overflow:hidden}
.vision::before{content:'';position:absolute;top:-200px;right:-200px;width:600px;height:600px;border-radius:50%;border:1px solid rgba(200,164,92,0.08);pointer-events:none}
.vision-inner{max-width:720px;margin-top:60px}
.vision-inner p{font-family:var(--serif-body);font-size:1.15rem;line-height:2;color:var(--text-body);font-weight:400;margin-bottom:24px}
.vision-quote{margin:48px 0 32px;padding:0 0 0 28px;border-left:2px solid var(--gold)}
.vision-quote blockquote{font-family:var(--serif-display);font-size:1.8rem;font-style:italic;color:var(--text-dark);line-height:1.55;font-weight:400}
.vision-quote cite{display:block;margin-top:16px;font-family:var(--sans);font-style:normal;font-size:0.75rem;color:var(--gold);letter-spacing:3px;text-transform:uppercase}

/* ═══ INFRA ═══ */
.infra{background:var(--cream)}
.infra-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:60px}
.infra-item{background:#fff;padding:40px 32px;transition:all .5s var(--ease);cursor:default;overflow:hidden;position:relative;border-radius:12px;border:1px solid rgba(200,164,92,0.12);box-shadow:0 2px 12px rgba(0,0,0,0.03)}
.infra-item::before{content:'';position:absolute;bottom:0;left:0;width:100%;height:3px;background:linear-gradient(90deg,var(--gold),#6b3a4a);transform:scaleX(0);transform-origin:left;transition:transform .5s var(--ease);border-radius:0 0 12px 12px}
.infra-item:hover{background:#fff;box-shadow:0 8px 32px rgba(200,164,92,0.1);transform:translateY(-4px)}
.infra-item:hover::before{transform:scaleX(1)}
.infra-item .icon{width:44px;height:44px;margin-bottom:20px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:linear-gradient(135deg,rgba(200,164,92,0.12),rgba(200,164,92,0.04));padding:10px;transition:all .4s}
.infra-item .icon svg{width:22px;height:22px;stroke:var(--gold);stroke-width:1.5;fill:none;stroke-linecap:round;stroke-linejoin:round}
.infra-item:hover .icon{background:linear-gradient(135deg,rgba(200,164,92,0.2),rgba(200,164,92,0.08));transform:scale(1.1)}
.infra-item h3{font-family:var(--serif-display);font-size:1.15rem;font-weight:500;color:var(--text-dark);margin-bottom:12px}
.infra-item p{font-family:var(--serif-body);font-size:1rem;line-height:1.75;color:var(--text-muted)}

/* ═══ SERVICES ═══ */
.services{background:var(--midnight);color:#fff;position:relative;overflow:hidden}
.services::after{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:800px;height:800px;border-radius:50%;border:1px solid rgba(200,164,92,0.04);pointer-events:none}
.services .sec-title{color:#fff}.services .sec-desc{color:rgba(255,255,255,0.45)}
.svc-tabs{display:flex;gap:6px;margin:60px 0 0;position:relative;z-index:2;background:rgba(255,255,255,0.04);border-radius:10px;padding:4px}
.svc-tab{flex:1;padding:16px 12px;font-family:var(--sans);font-size:0.82rem;font-weight:400;color:rgba(255,255,255,0.3);background:transparent;border:none;border-bottom:none;cursor:pointer;transition:all .3s;letter-spacing:.5px;text-align:center;border-radius:8px}
.svc-tab:hover{color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.06)}
.svc-tab.active{color:var(--gold);background:rgba(200,164,92,0.1)}
.svc-panel{display:none;padding-top:8px;position:relative;z-index:2}
.svc-panel.active{display:block;animation:fadeUp .5s var(--ease)}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.svc-row{display:grid;grid-template-columns:1.2fr 2fr .8fr 1fr;gap:20px;padding:24px 28px;border-bottom:1px solid rgba(255,255,255,0.05);transition:all .3s;align-items:start;border-radius:8px;margin-bottom:2px}
.svc-row:not(.header):hover{background:rgba(255,255,255,0.03)}
.svc-row.header{padding:16px 28px;border-bottom:1px solid rgba(200,164,92,0.2)}
.svc-row.header span{font-size:0.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:500}
.svc-name{font-family:var(--serif-body);font-size:1.05rem;color:#fff;font-weight:500}
.svc-detail{font-size:0.88rem;color:rgba(255,255,255,0.5);line-height:1.65;font-weight:300}
.svc-price{font-family:var(--serif-display);font-size:1.05rem;color:var(--gold-pale);font-weight:500;text-align:right}
.svc-note{font-size:0.8rem;color:rgba(255,255,255,0.3);font-weight:300;text-align:right}

/* ═══ PACKAGES ═══ */
.packages{background:var(--ivory);overflow:visible}
.pkg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:72px}
.pkg-card{padding:56px 40px;text-align:center;position:relative;transition:all .5s var(--ease);background:#fff;border-radius:16px;overflow:visible;border:1px solid rgba(200,164,92,0.12);box-shadow:0 2px 16px rgba(0,0,0,0.04)}
.pkg-card:hover{transform:translateY(-6px);box-shadow:0 12px 40px rgba(200,164,92,0.12)}
.pkg-card.feat{background:var(--midnight);color:#fff;border-color:var(--gold);box-shadow:0 4px 24px rgba(200,164,92,0.15)}
.pkg-card.feat:hover{background:var(--deep);transform:translateY(-6px);box-shadow:0 16px 48px rgba(200,164,92,0.2)}
.pkg-card.feat .pkg-tier{color:var(--gold)}.pkg-card.feat .pkg-name{color:#fff}.pkg-card.feat .pkg-price{color:var(--gold-pale)}.pkg-card.feat .pkg-note{color:rgba(255,255,255,0.4)}.pkg-card.feat .pkg-list li{color:rgba(255,255,255,0.6);border-color:rgba(255,255,255,0.08)}.pkg-card.feat .pkg-list li::before{color:var(--gold)}
.pkg-badge{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:var(--gold);color:var(--midnight);font-size:0.6rem;letter-spacing:3px;text-transform:uppercase;padding:6px 20px;font-weight:700;white-space:nowrap;z-index:2;border-radius:20px}
.pkg-tier{font-family:var(--sans);font-size:0.65rem;letter-spacing:5px;text-transform:uppercase;color:var(--text-muted);margin-bottom:16px}
.pkg-icon{width:48px;height:48px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:linear-gradient(135deg,rgba(200,164,92,0.12),rgba(200,164,92,0.04))}
.pkg-icon svg{width:24px;height:24px;stroke:var(--gold);stroke-width:1.5;fill:none;stroke-linecap:round;stroke-linejoin:round}
.pkg-card.feat .pkg-icon{background:linear-gradient(135deg,rgba(200,164,92,0.2),rgba(200,164,92,0.08))}
.pkg-card.feat .pkg-icon svg{stroke:var(--gold-pale)}
.pkg-name{font-family:var(--serif-display);font-size:1.8rem;font-weight:500;color:var(--text-dark);margin-bottom:12px}
.pkg-price{font-family:var(--serif-display);font-size:1.4rem;color:var(--gold);font-weight:500;margin-bottom:6px}
.pkg-note{font-size:0.78rem;color:var(--text-muted);margin-bottom:36px;font-weight:300}
.pkg-line{width:32px;height:1px;background:var(--gold);margin:0 auto 28px}
.pkg-list{list-style:none;text-align:left}
.pkg-list li{font-family:var(--serif-body);font-size:0.98rem;color:var(--text-body);padding:12px 0;border-bottom:1px solid rgba(0,0,0,0.05);display:flex;align-items:flex-start;gap:12px;line-height:1.55}
.pkg-list li::before{content:'✦';color:var(--gold);font-size:0.6rem;margin-top:5px;flex-shrink:0}

/* ═══ ROADMAP ═══ */
.roadmap{background:var(--cream)}
.tl{margin-top:60px;position:relative;padding-left:60px}
.tl::before{content:'';position:absolute;left:23px;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,var(--gold),var(--warm),transparent)}
.tl-phase{margin-bottom:72px}
.tl-head{display:flex;align-items:center;gap:20px;margin-bottom:24px;margin-left:-60px}
.tl-dot{width:46px;height:46px;border-radius:50%;background:var(--midnight);display:flex;align-items:center;justify-content:center;font-family:var(--serif-display);font-size:1rem;color:var(--gold);font-weight:500;flex-shrink:0;border:3px solid var(--cream);box-shadow:0 0 0 1px var(--midnight)}
.tl-meta h3{font-family:var(--serif-display);font-size:1.3rem;color:var(--text-dark);font-weight:500;margin-bottom:2px}
.tl-meta span{font-size:0.78rem;color:var(--text-muted);letter-spacing:1px;font-weight:300}
.tl-items{display:grid;gap:12px}
.tl-item{background:var(--ivory);border:1px solid rgba(200,164,92,0.12);padding:22px 28px;display:flex;justify-content:space-between;align-items:center;gap:20px;transition:all .3s;border-radius:10px}
.tl-item:hover{background:#fff;border-color:var(--gold);box-shadow:0 4px 20px rgba(200,164,92,0.08)}
.tl-item p{font-family:var(--serif-body);font-size:1rem;color:var(--text-body);line-height:1.6}
.tl-kpi{font-size:0.72rem;letter-spacing:1px;color:var(--gold);font-weight:500;white-space:nowrap;background:var(--gold-glow);padding:6px 16px;border-radius:20px;flex-shrink:0}

/* ═══ ECOSYSTEM ═══ */
.ecosystem{background:var(--deep);color:#fff;text-align:center;position:relative;overflow:hidden}
.ecosystem::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 20% 80%,rgba(107,58,74,0.15) 0%,transparent 50%),radial-gradient(ellipse 60% 80% at 80% 20%,rgba(58,90,94,0.1) 0%,transparent 50%)}
.ecosystem .container{position:relative;z-index:1}.ecosystem .sec-title{color:#fff}.ecosystem .sec-desc{color:rgba(255,255,255,0.4);margin:0 auto 72px}

/* Circular flow — redesigned */
.eco-diagram{position:relative;width:480px;height:480px;margin:0 auto 90px}

/* Outer decorative rings */
.eco-diagram .ring{position:absolute;border-radius:50%;border:1px solid rgba(200,164,92,0.08)}
.eco-diagram .ring-1{inset:-30px;border-style:dashed;animation:ringRotate 60s linear infinite}
.eco-diagram .ring-2{inset:0;border-color:rgba(200,164,92,0.15)}
.eco-diagram .ring-3{inset:30px;border-style:dashed;border-color:rgba(200,164,92,0.06);animation:ringRotate 45s linear infinite reverse}
@keyframes ringRotate{to{transform:rotate(360deg)}}

/* Center logo */
.eco-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:120px;height:120px;border-radius:50%;background:radial-gradient(circle,rgba(200,164,92,0.12) 0%,transparent 70%);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:3}
.eco-center-icon{margin-bottom:6px}
.eco-center span{font-family:var(--serif-display);font-size:0.7rem;letter-spacing:3px;text-transform:uppercase;color:var(--gold);font-weight:500}

/* Nodes */
.eco-node-wrap{position:absolute;z-index:4;transform:translate(-50%,-50%)}
.eco-node-wrap .node-glow{position:absolute;inset:-12px;border-radius:50%;background:radial-gradient(circle,rgba(200,164,92,0.15) 0%,transparent 70%);opacity:0;transition:opacity .4s}
.eco-node-wrap:hover .node-glow{opacity:1}

.eco-node-inner{width:110px;height:110px;border-radius:50%;background:var(--charcoal);border:1.5px solid rgba(200,164,92,0.25);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;transition:all .4s var(--ease);cursor:default;position:relative;overflow:hidden}
.eco-node-inner::before{content:'';position:absolute;inset:0;border-radius:50%;background:radial-gradient(circle at 30% 30%,rgba(255,255,255,0.04) 0%,transparent 60%)}
.eco-node-wrap:hover .eco-node-inner{border-color:var(--gold);background:rgba(200,164,92,0.08);transform:scale(1.08);box-shadow:0 0 40px rgba(200,164,92,0.15)}

.eco-node-inner .node-icon{width:24px;height:24px;flex-shrink:0;display:block;position:relative;z-index:2}
.eco-node-inner .node-icon svg{width:24px;height:24px;stroke:var(--gold-pale);stroke-width:1.5;fill:none;stroke-linecap:round;stroke-linejoin:round;display:block}
.eco-node-inner .node-label{font-family:var(--serif-display);font-size:0.95rem;font-weight:500;color:var(--gold-pale);letter-spacing:1px;line-height:1.2;position:relative;z-index:2}
.eco-node-inner .node-sub{font-size:0.5rem;color:rgba(255,255,255,0.3);letter-spacing:1.5px;text-transform:uppercase;font-weight:400;line-height:1;position:relative;z-index:2}

/* Node positions — on the ring circle edge */
.eco-node-wrap.n-top{top:0;left:50%}
.eco-node-wrap.n-right{top:50%;left:100%}
.eco-node-wrap.n-bottom{top:100%;left:50%}
.eco-node-wrap.n-left{top:50%;left:0}

/* SVG arrows */
.eco-diagram svg{position:absolute;inset:0;width:100%;height:100%;z-index:2}
.eco-arrow-path{fill:none;stroke:url(#goldGrad);stroke-width:1.5;stroke-dasharray:6,4;animation:dashFlow 12s linear infinite}
@keyframes dashFlow{to{stroke-dashoffset:-200}}
.eco-arrow-head{fill:var(--gold);opacity:0.7}

/* Floating particles around the ring */
.eco-particle{position:absolute;width:4px;height:4px;border-radius:50%;background:var(--gold);opacity:0;z-index:1}
.eco-particle.active{animation:orbitParticle var(--dur) linear infinite}
@keyframes orbitParticle{
  0%{opacity:0;transform:rotate(var(--start)) translateX(240px) scale(0.5)}
  10%{opacity:0.6}
  90%{opacity:0.6}
  100%{opacity:0;transform:rotate(calc(var(--start) + 360deg)) translateX(240px) scale(0.5)}
}

